<mvc:View
	controllerName="downport.blocks.orderdetails.OrderDetails"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m">
	<!-- Empty shell. The controller builds the columns from the Order_Detail
	     UI.v1.LineItem annotation and binds the rows to the Order_Details
	     navigation collection. The header toolbar gets one button per
	     UI.DataFieldForAction in the LineItem, each running via
	     util/AsyncActionRunner; on success the controller refreshes the rows. -->
	<Table id="table" growing="true" growingThreshold="20">
		<headerToolbar>
			<OverflowToolbar id="actions" visible="false">
				<Title text="Order Details"/>
				<ToolbarSpacer/>
			</OverflowToolbar>
		</headerToolbar>
	</Table>
</mvc:View>
