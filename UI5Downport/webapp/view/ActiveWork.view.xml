<mvc:View
	controllerName="downport.controller.ActiveWork"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:annotation="downport.annotation"
	xmlns:mdcTable="sap.ui.mdc.table"
	displayBlock="true"
	height="100%">
	<Page id="activeWorkPage"
		title="Active Work — Low Stock Products"
		showNavButton="true"
		navButtonPress=".onNavBack"
		class="sapUiContentPadding">
		<content>
			<annotation:AnnotationTable
				id="lowStockTable"
				contextPath="/Products"
				metaPath="@com.sap.vocabularies.UI.v1.LineItem#ActiveWork"
				selectionVariantPath="@com.sap.vocabularies.UI.v1.SelectionVariant#LowStock"
				collectionPath="/Products"
				header="Low Stock"
				showRowCount="true"
				autoBindOnInit="true"
				p13nMode="Column,Sort"
				rowPress=".onProductPress">
				<annotation:type>
					<mdcTable:ResponsiveTableType growingMode="Scroll"/>
				</annotation:type>
			</annotation:AnnotationTable>
		</content>
	</Page>
</mvc:View>
