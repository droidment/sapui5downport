<mvc:View
	controllerName="downport.controller.Main"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:mdc="sap.ui.mdc"
	xmlns:mdcTable="sap.ui.mdc.table"
	displayBlock="true"
	height="100%">
	<Page id="page" title="MDC FilterBar + Table + ValueHelps on OpenUI5 1.120.30 (OData V4 / Northwind)" class="sapUiContentPadding">
		<content>
			<!-- ===================== FILTER BAR =====================
			     No FilterFields declared here. They are generated at runtime from the
			     Product UI.SelectionFields annotation (Main.controller ->
			     util/MetadataDriven), the freestyle analogue of the sap.fe.macros
			     FilterBar building block. Each field's value help is likewise driven by
			     the property's Common.ValueList annotation. -->
			<mdc:FilterBar id="filterBar"
				p13nMode="Value"
				delegate="{name: 'downport/delegate/FilterBarMainDelegate', payload: {}}"/>

			<!-- ===================== CUSTOM FILTER ROW =====================
			     "In WIP" is NOT an MDC FilterField (MDC FilterBar only hosts
			     FilterFields). It is a plain Switch whose state lives in the
			     unnamed-view "ui" JSON model. On search the TableDelegate reads
			     ui>/inWIP and appends a custom condition to the $filter query. -->
			<Toolbar id="customFilters" class="sapUiSmallMarginTop">
				<Label text="In WIP" labelFor="swInWIP"/>
				<Switch id="swInWIP" state="{ui>/inWIP}" change=".onWIPChange"
					customTextOn="WIP" customTextOff="All"/>
				<ToolbarSpacer/>
			</Toolbar>

			<!-- ===================== RESULTS TABLE =====================
			     No columns or actions declared here either. They are generated at
			     runtime from the Product UI.LineItem annotation (DataField -> column,
			     DataFieldForAction -> toolbar action), the freestyle analogue of the
			     sap.fe.macros Table building block.
			     autoBindOnInit="false": the controller rebinds once the annotation-driven
			     columns exist, so the first request's $select is complete. -->
			<mdc:Table id="productsTable"
				header="Products"
				showRowCount="true"
				autoBindOnInit="false"
				p13nMode="Column,Sort"
				selectionMode="Multi"
				threshold="50"
				filter="filterBar"
				rowPress=".onProductPress"
				class="sapUiSmallMarginTop"
				delegate="{name: 'downport/delegate/TableDelegate', payload: {collectionPath: '/Products'}}">
				<mdc:type>
					<mdcTable:ResponsiveTableType growingMode="Scroll"/>
				</mdc:type>
			</mdc:Table>
		</content>
	</Page>
</mvc:View>
