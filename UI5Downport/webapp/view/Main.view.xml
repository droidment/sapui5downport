<mvc:View
	controllerName="downport.controller.Main"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:annotation="downport.annotation"
	xmlns:mdcTable="sap.ui.mdc.table"
	displayBlock="true"
	height="100%">
	<Page id="page" title="Annotation-Driven Products" class="sapUiContentPadding">
		<content>
			<annotation:AnnotationFilterBar
				id="filterBar"
				contextPath="/Products"
				metaPath="@com.sap.vocabularies.UI.v1.SelectionFields"
				p13nMode="Value"/>
			<Toolbar class="sapUiSmallMarginTop">
				<annotation:SelectionVariantFilter
					contextPath="/Products"
					metaPath="@com.sap.vocabularies.UI.v1.SelectionVariant#InWIP"
					filterBar="filterBar"/>
				<ToolbarSpacer/>
			</Toolbar>
			<annotation:AnnotationTable
				id="productsTable"
				contextPath="/Products"
				metaPath="@com.sap.vocabularies.UI.v1.LineItem"
				collectionPath="/Products"
				header="Products"
				showRowCount="true"
				autoBindOnInit="true"
				p13nMode="Column,Sort"
				selectionMode="Multi"
				threshold="50"
				filter="filterBar"
				rowPress=".onProductPress"
				annotationAction=".onAnnotationAction"
				class="sapUiSmallMarginTop">
				<annotation:type>
					<mdcTable:ResponsiveTableType growingMode="Scroll"/>
				</annotation:type>
			</annotation:AnnotationTable>
		</content>
	</Page>
</mvc:View>
