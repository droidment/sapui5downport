<mvc:View
	controllerName="downport.controller.ObjectPage"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:uxap="sap.uxap"
	displayBlock="true"
	height="100%">
	<Page id="objectPage" showNavButton="true" navButtonPress=".onNavBack" class="sapUiNoContentPadding">
		<content>
			<!-- Traditional UXAP shell: HeaderInfo drives title/subtitle; Facets become
			     ObjectPageSections with BlockBase content under the anchor bar. -->
			<uxap:ObjectPageLayout
				id="objectPageLayout"
				showTitleInHeaderContent="false"
				showHeaderContent="true"
				showAnchorBar="true"
				useIconTabBar="false"
				alwaysShowContentHeader="true">
				<uxap:headerTitle>
					<uxap:ObjectPageHeader id="opHeader" objectTitle="" objectSubtitle=""/>
				</uxap:headerTitle>
				<uxap:headerContent>
					<VBox class="sapUiSmallMarginEnd">
						<Label text="Product ID"/>
						<Text text="{ProductID}"/>
					</VBox>
					<VBox class="sapUiSmallMarginEnd">
						<Label text="Unit Price"/>
						<ObjectNumber number="{UnitPrice}" unit="USD"/>
					</VBox>
					<VBox class="sapUiSmallMarginEnd">
						<Label text="Units In Stock"/>
						<Text text="{UnitsInStock}"/>
					</VBox>
					<VBox class="sapUiSmallMarginEnd">
						<Label text="Units On Order"/>
						<Text text="{UnitsOnOrder}"/>
					</VBox>
					<ObjectStatus
						title="Discontinued"
						text="{path:'Discontinued', formatter:'.formatDiscontinuedText'}"
						state="{path:'Discontinued', formatter:'.formatDiscontinuedState'}"/>
				</uxap:headerContent>
			</uxap:ObjectPageLayout>
		</content>
	</Page>
</mvc:View>
