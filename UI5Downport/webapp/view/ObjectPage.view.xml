<mvc:View
	controllerName="downport.controller.ObjectPage"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:annotation="downport.annotation"
	displayBlock="true"
	height="100%">
	<Page id="objectPage"
		showNavButton="true"
		navButtonPress=".onNavBack"
		class="sapUiNoContentPadding">
		<content>
			<annotation:AnnotationObjectPage
				id="annotationObjectPage"
				contextPath="/Products"
				headerInfoPath="@com.sap.vocabularies.UI.v1.HeaderInfo"
				facetsPath="@com.sap.vocabularies.UI.v1.Facets"
				annotationAction=".onAnnotationAction"/>
		</content>
	</Page>
</mvc:View>
