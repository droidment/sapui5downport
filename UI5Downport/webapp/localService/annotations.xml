<?xml version="1.0" encoding="utf-8"?>
<edmx:Edmx Version="4.0" xmlns:edmx="http://docs.oasis-open.org/odata/ns/edmx">
	<!-- No edmx:Reference to the Common/UI vocabularies on purpose: the V4
	     ODataMetaModel ships those standard com.sap.vocabularies.* terms built
	     in, and the live Northwind service already references them, so a second
	     declaration here is unnecessary. -->
	<edmx:DataServices>
		<Schema Namespace="downport.annotations" xmlns="http://docs.oasis-open.org/odata/ns/edm">

			<!-- ============ Value helps ============ -->
			<Annotations Target="NorthwindModel.Product/ProductName">
				<Annotation Term="com.sap.vocabularies.Common.v1.ValueList">
					<Record Type="com.sap.vocabularies.Common.v1.ValueListType">
						<PropertyValue Property="Label" String="Product"/>
						<PropertyValue Property="CollectionPath" String="Products"/>
						<PropertyValue Property="Parameters">
							<Collection>
								<Record Type="com.sap.vocabularies.Common.v1.ValueListParameterInOut">
									<PropertyValue Property="LocalDataProperty" PropertyPath="ProductName"/>
									<PropertyValue Property="ValueListProperty" String="ProductName"/>
								</Record>
								<Record Type="com.sap.vocabularies.Common.v1.ValueListParameterDisplayOnly">
									<PropertyValue Property="ValueListProperty" String="QuantityPerUnit"/>
								</Record>
								<Record Type="com.sap.vocabularies.Common.v1.ValueListParameterDisplayOnly">
									<PropertyValue Property="ValueListProperty" String="UnitPrice"/>
								</Record>
							</Collection>
						</PropertyValue>
					</Record>
				</Annotation>
			</Annotations>
			<Annotations Target="NorthwindModel.Product/CategoryID">
				<Annotation Term="com.sap.vocabularies.Common.v1.ValueList">
					<Record Type="com.sap.vocabularies.Common.v1.ValueListType">
						<PropertyValue Property="Label" String="Category"/>
						<PropertyValue Property="CollectionPath" String="Categories"/>
						<PropertyValue Property="Parameters">
							<Collection>
								<Record Type="com.sap.vocabularies.Common.v1.ValueListParameterInOut">
									<PropertyValue Property="LocalDataProperty" PropertyPath="CategoryID"/>
									<PropertyValue Property="ValueListProperty" String="CategoryID"/>
								</Record>
								<Record Type="com.sap.vocabularies.Common.v1.ValueListParameterDisplayOnly">
									<PropertyValue Property="ValueListProperty" String="CategoryName"/>
								</Record>
								<Record Type="com.sap.vocabularies.Common.v1.ValueListParameterDisplayOnly">
									<PropertyValue Property="ValueListProperty" String="Description"/>
								</Record>
							</Collection>
						</PropertyValue>
					</Record>
				</Annotation>
			</Annotations>
			<Annotations Target="NorthwindModel.Product/SupplierID">
				<Annotation Term="com.sap.vocabularies.Common.v1.ValueList">
					<Record Type="com.sap.vocabularies.Common.v1.ValueListType">
						<PropertyValue Property="Label" String="Supplier"/>
						<PropertyValue Property="CollectionPath" String="Suppliers"/>
						<PropertyValue Property="Parameters">
							<Collection>
								<Record Type="com.sap.vocabularies.Common.v1.ValueListParameterInOut">
									<PropertyValue Property="LocalDataProperty" PropertyPath="SupplierID"/>
									<PropertyValue Property="ValueListProperty" String="SupplierID"/>
								</Record>
								<Record Type="com.sap.vocabularies.Common.v1.ValueListParameterDisplayOnly">
									<PropertyValue Property="ValueListProperty" String="CompanyName"/>
								</Record>
								<Record Type="com.sap.vocabularies.Common.v1.ValueListParameterDisplayOnly">
									<PropertyValue Property="ValueListProperty" String="City"/>
								</Record>
								<Record Type="com.sap.vocabularies.Common.v1.ValueListParameterDisplayOnly">
									<PropertyValue Property="ValueListProperty" String="Country"/>
								</Record>
							</Collection>
						</PropertyValue>
					</Record>
				</Annotation>
			</Annotations>

			<!-- ============ Property labels ============ -->
			<Annotations Target="NorthwindModel.Product/ProductName">
				<Annotation Term="com.sap.vocabularies.Common.v1.Label" String="Product Name"/>
			</Annotations>
			<Annotations Target="NorthwindModel.Product/QuantityPerUnit">
				<Annotation Term="com.sap.vocabularies.Common.v1.Label" String="Quantity Per Unit"/>
			</Annotations>
			<Annotations Target="NorthwindModel.Product/UnitPrice">
				<Annotation Term="com.sap.vocabularies.Common.v1.Label" String="Unit Price"/>
			</Annotations>
			<Annotations Target="NorthwindModel.Product/UnitsInStock">
				<Annotation Term="com.sap.vocabularies.Common.v1.Label" String="Units In Stock"/>
			</Annotations>
			<Annotations Target="NorthwindModel.Product/UnitsOnOrder">
				<Annotation Term="com.sap.vocabularies.Common.v1.Label" String="Units On Order"/>
			</Annotations>
			<Annotations Target="NorthwindModel.Product/ReorderLevel">
				<Annotation Term="com.sap.vocabularies.Common.v1.Label" String="Reorder Level"/>
			</Annotations>
			<Annotations Target="NorthwindModel.Product/Discontinued">
				<Annotation Term="com.sap.vocabularies.Common.v1.Label" String="Discontinued"/>
			</Annotations>
			<Annotations Target="NorthwindModel.Product/CategoryID">
				<Annotation Term="com.sap.vocabularies.Common.v1.Label" String="Category"/>
				<Annotation Term="com.sap.vocabularies.Common.v1.Text" Path="Category/CategoryName">
					<Annotation Term="com.sap.vocabularies.Common.v1.TextArrangement"
						EnumMember="com.sap.vocabularies.Common.v1.TextArrangementType/TextOnly"/>
				</Annotation>
			</Annotations>
			<Annotations Target="NorthwindModel.Product/SupplierID">
				<Annotation Term="com.sap.vocabularies.Common.v1.Label" String="Supplier"/>
				<Annotation Term="com.sap.vocabularies.Common.v1.Text" Path="Supplier/CompanyName">
					<Annotation Term="com.sap.vocabularies.Common.v1.TextArrangement"
						EnumMember="com.sap.vocabularies.Common.v1.TextArrangementType/TextOnly"/>
				</Annotation>
			</Annotations>
			<Annotations Target="NorthwindModel.Product/ProductID">
				<Annotation Term="com.sap.vocabularies.Common.v1.Label" String="Product ID"/>
			</Annotations>
			<Annotations Target="NorthwindModel.Category/CategoryID">
				<Annotation Term="com.sap.vocabularies.Common.v1.Label" String="ID"/>
			</Annotations>
			<Annotations Target="NorthwindModel.Category/CategoryName">
				<Annotation Term="com.sap.vocabularies.Common.v1.Label" String="Category Name"/>
			</Annotations>
			<Annotations Target="NorthwindModel.Category/Description">
				<Annotation Term="com.sap.vocabularies.Common.v1.Label" String="Description"/>
			</Annotations>
			<Annotations Target="NorthwindModel.Supplier/SupplierID">
				<Annotation Term="com.sap.vocabularies.Common.v1.Label" String="ID"/>
			</Annotations>
			<Annotations Target="NorthwindModel.Supplier/CompanyName">
				<Annotation Term="com.sap.vocabularies.Common.v1.Label" String="Company Name"/>
			</Annotations>
			<Annotations Target="NorthwindModel.Supplier/City">
				<Annotation Term="com.sap.vocabularies.Common.v1.Label" String="City"/>
			</Annotations>
			<Annotations Target="NorthwindModel.Supplier/Country">
				<Annotation Term="com.sap.vocabularies.Common.v1.Label" String="Country"/>
			</Annotations>

			<!-- ============ Object Page structure (Product entity type) ============ -->
			<Annotations Target="NorthwindModel.Product">

				<Annotation Term="com.sap.vocabularies.UI.v1.SelectionFields">
					<Collection>
						<PropertyPath>ProductName</PropertyPath>
						<PropertyPath>CategoryID</PropertyPath>
						<PropertyPath>SupplierID</PropertyPath>
					</Collection>
				</Annotation>

				<Annotation Term="com.sap.vocabularies.UI.v1.LineItem">
					<Collection>
						<Record Type="com.sap.vocabularies.UI.v1.DataField"><PropertyValue Property="Value" Path="ProductID"/></Record>
						<Record Type="com.sap.vocabularies.UI.v1.DataField"><PropertyValue Property="Value" Path="ProductName"/></Record>
						<Record Type="com.sap.vocabularies.UI.v1.DataField"><PropertyValue Property="Value" Path="QuantityPerUnit"/></Record>
						<Record Type="com.sap.vocabularies.UI.v1.DataField"><PropertyValue Property="Value" Path="CategoryID"/></Record>
						<Record Type="com.sap.vocabularies.UI.v1.DataField"><PropertyValue Property="Value" Path="SupplierID"/></Record>
						<Record Type="com.sap.vocabularies.UI.v1.DataField"><PropertyValue Property="Value" Path="UnitPrice"/></Record>
						<Record Type="com.sap.vocabularies.UI.v1.DataField"><PropertyValue Property="Value" Path="UnitsInStock"/></Record>
						<Record Type="com.sap.vocabularies.UI.v1.DataFieldForAction">
							<PropertyValue Property="Label" String="Active Work"/>
							<PropertyValue Property="Action" String="downport.action.ActiveWork"/>
						</Record>
						<Record Type="com.sap.vocabularies.UI.v1.DataFieldForAction">
							<PropertyValue Property="Label" String="Passive Work"/>
							<PropertyValue Property="Action" String="downport.action.PassiveWork"/>
						</Record>
					</Collection>
				</Annotation>

				<Annotation Term="com.sap.vocabularies.UI.v1.LineItem" Qualifier="ActiveWork">
					<Collection>
						<Record Type="com.sap.vocabularies.UI.v1.DataField"><PropertyValue Property="Value" Path="ProductID"/></Record>
						<Record Type="com.sap.vocabularies.UI.v1.DataField"><PropertyValue Property="Value" Path="ProductName"/></Record>
						<Record Type="com.sap.vocabularies.UI.v1.DataField"><PropertyValue Property="Value" Path="UnitsInStock"/></Record>
						<Record Type="com.sap.vocabularies.UI.v1.DataField"><PropertyValue Property="Value" Path="UnitsOnOrder"/></Record>
						<Record Type="com.sap.vocabularies.UI.v1.DataField"><PropertyValue Property="Value" Path="ReorderLevel"/></Record>
						<Record Type="com.sap.vocabularies.UI.v1.DataField"><PropertyValue Property="Value" Path="UnitPrice"/></Record>
					</Collection>
				</Annotation>

				<Annotation Term="com.sap.vocabularies.UI.v1.SelectionVariant" Qualifier="LowStock">
					<Record Type="com.sap.vocabularies.UI.v1.SelectionVariantType">
						<PropertyValue Property="Text" String="Low Stock"/>
						<PropertyValue Property="SelectOptions">
							<Collection>
								<Record Type="com.sap.vocabularies.UI.v1.SelectOptionType">
									<PropertyValue Property="PropertyName" PropertyPath="UnitsInStock"/>
									<PropertyValue Property="Ranges">
										<Collection>
											<Record Type="com.sap.vocabularies.UI.v1.SelectionRangeType">
												<PropertyValue Property="Sign" EnumMember="com.sap.vocabularies.UI.v1.SelectionRangeSignType/I"/>
												<PropertyValue Property="Option" EnumMember="com.sap.vocabularies.UI.v1.SelectionRangeOptionType/LT"/>
												<PropertyValue Property="Low" Int="20"/>
											</Record>
										</Collection>
									</PropertyValue>
								</Record>
							</Collection>
						</PropertyValue>
					</Record>
				</Annotation>

				<Annotation Term="com.sap.vocabularies.UI.v1.SelectionVariant" Qualifier="InWIP">
					<Record Type="com.sap.vocabularies.UI.v1.SelectionVariantType">
						<PropertyValue Property="Text" String="In WIP"/>
						<PropertyValue Property="SelectOptions">
							<Collection>
								<Record Type="com.sap.vocabularies.UI.v1.SelectOptionType">
									<PropertyValue Property="PropertyName" PropertyPath="UnitsOnOrder"/>
									<PropertyValue Property="Ranges">
										<Collection>
											<Record Type="com.sap.vocabularies.UI.v1.SelectionRangeType">
												<PropertyValue Property="Sign" EnumMember="com.sap.vocabularies.UI.v1.SelectionRangeSignType/I"/>
												<PropertyValue Property="Option" EnumMember="com.sap.vocabularies.UI.v1.SelectionRangeOptionType/GT"/>
												<PropertyValue Property="Low" Int="0"/>
											</Record>
										</Collection>
									</PropertyValue>
								</Record>
							</Collection>
						</PropertyValue>
					</Record>
				</Annotation>

				<!-- Header: type names + which fields drive title/description -->
				<Annotation Term="com.sap.vocabularies.UI.v1.HeaderInfo">
					<Record Type="com.sap.vocabularies.UI.v1.HeaderInfoType">
						<PropertyValue Property="TypeName" String="Product"/>
						<PropertyValue Property="TypeNamePlural" String="Products"/>
						<PropertyValue Property="Title">
							<Record Type="com.sap.vocabularies.UI.v1.DataField">
								<PropertyValue Property="Value" Path="ProductName"/>
							</Record>
						</PropertyValue>
						<PropertyValue Property="Description">
							<Record Type="com.sap.vocabularies.UI.v1.DataField">
								<PropertyValue Property="Value" Path="QuantityPerUnit"/>
							</Record>
						</PropertyValue>
					</Record>
				</Annotation>

				<!-- Field group: General Information -->
				<Annotation Term="com.sap.vocabularies.UI.v1.FieldGroup" Qualifier="General">
					<Record Type="com.sap.vocabularies.UI.v1.FieldGroupType">
						<PropertyValue Property="Label" String="General Information"/>
						<PropertyValue Property="Data">
							<Collection>
								<Record Type="com.sap.vocabularies.UI.v1.DataField">
									<PropertyValue Property="Value" Path="ProductName"/>
								</Record>
								<Record Type="com.sap.vocabularies.UI.v1.DataField">
									<PropertyValue Property="Value" Path="QuantityPerUnit"/>
								</Record>
								<Record Type="com.sap.vocabularies.UI.v1.DataField">
									<PropertyValue Property="Value" Path="CategoryID"/>
								</Record>
								<Record Type="com.sap.vocabularies.UI.v1.DataField">
									<PropertyValue Property="Value" Path="SupplierID"/>
								</Record>
								<!-- Custom action: the block renders this as a button that
								     routes through util/AsyncActionRunner (trigger + poll),
								     NOT a standard OData action POST. Action is a logical id
								     interpreted by the runner, not an EDM action import. -->
								<Record Type="com.sap.vocabularies.UI.v1.DataFieldForAction">
									<PropertyValue Property="Label" String="Duplicate Product"/>
									<PropertyValue Property="Action" String="downport.action.DuplicateProduct"/>
								</Record>
							</Collection>
						</PropertyValue>
					</Record>
				</Annotation>

				<!-- Field group: Stock & Pricing -->
				<Annotation Term="com.sap.vocabularies.UI.v1.FieldGroup" Qualifier="Stock">
					<Record Type="com.sap.vocabularies.UI.v1.FieldGroupType">
						<PropertyValue Property="Label" String="Stock &amp; Pricing"/>
						<PropertyValue Property="Data">
							<Collection>
								<Record Type="com.sap.vocabularies.UI.v1.DataField">
									<PropertyValue Property="Value" Path="UnitPrice"/>
								</Record>
								<Record Type="com.sap.vocabularies.UI.v1.DataField">
									<PropertyValue Property="Value" Path="UnitsInStock"/>
								</Record>
								<Record Type="com.sap.vocabularies.UI.v1.DataField">
									<PropertyValue Property="Value" Path="UnitsOnOrder"/>
								</Record>
								<Record Type="com.sap.vocabularies.UI.v1.DataField">
									<PropertyValue Property="Value" Path="ReorderLevel"/>
								</Record>
								<Record Type="com.sap.vocabularies.UI.v1.DataField">
									<PropertyValue Property="Value" Path="Discontinued"/>
								</Record>
								<!-- Custom action -> async runner (see util/AsyncActionRunner). -->
								<Record Type="com.sap.vocabularies.UI.v1.DataFieldForAction">
									<PropertyValue Property="Label" String="Reorder Stock"/>
									<PropertyValue Property="Action" String="downport.action.ReorderStock"/>
								</Record>
							</Collection>
						</PropertyValue>
					</Record>
				</Annotation>

				<!-- Facets: which field groups become Object Page sections, in order -->
				<Annotation Term="com.sap.vocabularies.UI.v1.Facets">
					<Collection>
						<Record Type="com.sap.vocabularies.UI.v1.ReferenceFacet">
							<PropertyValue Property="Label" String="General Information"/>
							<PropertyValue Property="Target" AnnotationPath="@com.sap.vocabularies.UI.v1.FieldGroup#General"/>
						</Record>
						<Record Type="com.sap.vocabularies.UI.v1.ReferenceFacet">
							<PropertyValue Property="Label" String="Stock &amp; Pricing"/>
							<PropertyValue Property="Target" AnnotationPath="@com.sap.vocabularies.UI.v1.FieldGroup#Stock"/>
						</Record>
						<!-- 1..many table facet: Target is a navigation path to the
						     Order_Details collection's LineItem. The Object Page renders
						     this as a table and (because the controller loads sections
						     lazily) only requests the rows when the user opens it. -->
						<Record Type="com.sap.vocabularies.UI.v1.ReferenceFacet">
							<PropertyValue Property="Label" String="Order Details"/>
							<PropertyValue Property="Target" AnnotationPath="Order_Details/@com.sap.vocabularies.UI.v1.LineItem"/>
						</Record>
					</Collection>
				</Annotation>

			</Annotations>

			<!-- ============ Order_Detail (1..many child of Product) ============ -->
			<Annotations Target="NorthwindModel.Order_Detail/OrderID">
				<Annotation Term="com.sap.vocabularies.Common.v1.Label" String="Order ID"/>
			</Annotations>
			<Annotations Target="NorthwindModel.Order_Detail/UnitPrice">
				<Annotation Term="com.sap.vocabularies.Common.v1.Label" String="Unit Price"/>
			</Annotations>
			<Annotations Target="NorthwindModel.Order_Detail/Quantity">
				<Annotation Term="com.sap.vocabularies.Common.v1.Label" String="Quantity"/>
			</Annotations>
			<Annotations Target="NorthwindModel.Order_Detail/Discount">
				<Annotation Term="com.sap.vocabularies.Common.v1.Label" String="Discount"/>
			</Annotations>

			<!-- Line item: the columns of the Order Details table, in order -->
			<Annotations Target="NorthwindModel.Order_Detail">
				<Annotation Term="com.sap.vocabularies.UI.v1.LineItem">
					<Collection>
						<Record Type="com.sap.vocabularies.UI.v1.DataField">
							<PropertyValue Property="Value" Path="OrderID"/>
						</Record>
						<Record Type="com.sap.vocabularies.UI.v1.DataField">
							<PropertyValue Property="Value" Path="UnitPrice"/>
						</Record>
						<Record Type="com.sap.vocabularies.UI.v1.DataField">
							<PropertyValue Property="Value" Path="Quantity"/>
						</Record>
						<Record Type="com.sap.vocabularies.UI.v1.DataField">
							<PropertyValue Property="Value" Path="Discount"/>
						</Record>
						<!-- Table-level custom action. The Order Details block renders this
						     as a header-toolbar button that fires the async runner
						     (trigger + poll) and refreshes the table on success. -->
						<Record Type="com.sap.vocabularies.UI.v1.DataFieldForAction">
							<PropertyValue Property="Label" String="Create New Order"/>
							<PropertyValue Property="Action" String="downport.action.CreateOrder"/>
						</Record>
					</Collection>
				</Annotation>
			</Annotations>

		</Schema>
	</edmx:DataServices>
</edmx:Edmx>
